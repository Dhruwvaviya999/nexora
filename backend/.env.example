# =============================================================================
# Backend environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored and must never be committed.
# =============================================================================

# Which settings module to load. Leave as development locally; deploys set
# this to config.settings.production in their own environment.
DJANGO_SETTINGS_MODULE=config.settings.development

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Cryptographic signing key for sessions, CSRF, password resets, etc.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

# Toggle debug mode. MUST be False in production (verbose errors leak internals).
DEBUG=True

# -----------------------------------------------------------------------------
# Hosts
# -----------------------------------------------------------------------------
# Comma-separated host/domain names Django will serve. In production list your
# real domains, e.g. api.example.com,example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database (single PostgreSQL instance)
# -----------------------------------------------------------------------------
# Connection string parsed by django-environ:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://nexora:nexora@localhost:5432/nexora

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated front-end origins allowed to call the API (scheme + host + port).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# JWT (SimpleJWT) — tokens are wired up, auth endpoints come in Phase 2
# -----------------------------------------------------------------------------
# Access token lifetime in minutes (short-lived).
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
# Refresh token lifetime in days (longer-lived).
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
# Optional dedicated signing key for JWTs. If omitted, SECRET_KEY is used.
JWT_SIGNING_KEY=

# -----------------------------------------------------------------------------
# AI / RAG (Phase 5)
# -----------------------------------------------------------------------------
# Default LLM provider for chat/summaries: gemini | openai | ollama.
# Per-workspace AI Settings (set in the UI) override these.
AI_LLM_PROVIDER=gemini
AI_CHAT_MODEL=gemini-2.0-flash
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1024

# Embeddings. Default is the local Sentence Transformers model (no key needed).
# EMBEDDING_DIM is fixed at 384 in code/migrations for this model.
AI_EMBEDDING_PROVIDER=sentence_transformer
AI_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Provider API keys (fallbacks; per-workspace keys take precedence).
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Fernet key encrypting per-workspace API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, a key is derived from SECRET_KEY (acceptable for development only).
AI_FIELD_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Production-only (safe to leave unset in development)
# -----------------------------------------------------------------------------
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=2592000
